# ── Servidor ────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Shopee Affiliate API ────────────────────────────
# Obter em: https://open.affiliate.shopee.com.br/
SHOPEE_APP_ID=SEU_SHOPEE_APP_ID
SHOPEE_APP_SECRET=SEU_SHOPEE_APP_SECRET

# ── Mercado Livre ────────────────────────────────────
ML_AFFILIATE_TOOL=garagem_pro

# ── Amazon ───────────────────────────────────────────
# Obter em: https://associados.amazon.com.br/
AMAZON_AFFILIATE_TAG=SEU_TAG-20

# ── Segurança ────────────────────────────────────────
# Gere com: openssl rand -hex 32
# Coloque o MESMO valor em local.properties (Android) e aqui
API_SECRET_KEY=gere_uma_chave_aleatoria_aqui

# ── Cache ────────────────────────────────────────────
CACHE_TTL_SECONDS=3600
